{
  "name": "thehogcli",
  "version": "1.0.1",
  "description": "A PostHog CLI that mirrors the PostHog MCP tool surface without the ~250k-token schema overhead. OAuth login with scopes derived from the registry. Every call is captured locally in .thehogcli/history.db with a required --why annotation and re-runnable by id.",
  "keywords": [
    "posthog",
    "cli",
    "mcp",
    "analytics",
    "hogql",
    "feature-flags",
    "claude-code",
    "agent"
  ],
  "author": "Kumar Divya Rajat <rajat.ady@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/rajatady/posthog-cli",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/rajatady/posthog-cli.git"
  },
  "bugs": {
    "url": "https://github.com/rajatady/posthog-cli/issues"
  },
  "bin": {
    "thehogcli": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:extract": "tsx build/extract.ts",
    "build:ts": "tsc -p tsconfig.build.json",
    "build": "npm run build:extract && npm run build:ts",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "sync:posthog": "bash scripts/sync-posthog.sh",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "kleur": "^4.1.5",
    "undici": "^6.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.5",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
