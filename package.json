{
  "name": "thehogcli",
  "version": "0.0.1",
  "description": "A PostHog CLI that mirrors the PostHog MCP tool surface without the 250k-token schema overhead. Every call is captured locally in .thehogcli/history.db and re-runnable by id.",
  "bin": {
    "thehogcli": "dist/index.js"
  },
  "files": [
    "dist/",
    "src/registry.json",
    "thehogcli.skill.md"
  ],
  "scripts": {
    "build:extract": "tsx build/extract.ts",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:extract && npm run build:ts",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "sync:posthog": "bash scripts/sync-posthog.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "kleur": "^4.1.5",
    "undici": "^6.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
